# Python
__pycache__/
*.pyc
*.pyo

# Virtual environments
env/
venv/
.venv/
budget-env/

# Uploads (contains sensitive data)
uploads/
*.csv
*.pdf
*.png
*.jpg
*.jpeg
*.txt
# But do track requirements files and test fixtures
!requirements*.txt
!tests/fixtures/*.txt

# Database (contains actual transactions)
instance/
*.db
*.sqlite
*.sqlite3

# Secrets
config.py
.env
*.env

# IDE files
.vscode/
.idea/
.DS_Store

# Backup, temp, and patch files
*.bak*
*.patch
backups_ocr_upgrade/
backup_before_premium_*/
backup_final_bomb_*/

# Local backup archives
*.tar.gz
*.zip

# Old / archived experiments — keep out of active dev
old1/
archive/

# Test cache
.pytest_cache/
.coverage
htmlcov/
