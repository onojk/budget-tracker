# Copy to .env and customize. .env is gitignored.

# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Default uses local SQLite at ./budget.db
# DATABASE_URL=sqlite:///budget.db

# Optional: explicit path to tesseract if not on PATH
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
